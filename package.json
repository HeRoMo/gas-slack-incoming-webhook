{
  "name": "gas-slack-incoming-webhook",
  "version": "1.1.0",
  "description": "Slack Incoming Webhook for GAS",
  "main": "index.js",
  "author": "HeRoMo",
  "license": "MIT",
  "private": false,
  "scripts": {
    "build": "tsc && cp src/appsscript.json dist/",
    "eslint": "eslint .",
    "clasp:push": "yarn build && ./node_modules/.bin/clasp push",
    "clasp:open": "./node_modules/.bin/clasp open",
    "clasp:status": "./node_modules/.bin/clasp status",
    "clasp:deployments": "./node_modules/.bin/clasp deployments",
    "clasp:create": "./node_modules/.bin/clasp create --type api --rootDir dist"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@google/clasp": "3.3.0",
    "@types/google-apps-script": "2.0.8",
    "@typescript-eslint/eslint-plugin": "8.59.2",
    "@typescript-eslint/parser": "8.59.2",
    "eslint": "^10.3.0",
    "eslint-plugin-googleappsscript": "1.0.5",
    "eslint-plugin-import": "2.32.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@slack/types": "^2.21.0"
  }
}
