{
  "compilerOptions": {
    "target": "ES2020",
    "module": "none",
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@slack/types": ["node_modules/@slack/types/dist/index.d.ts"]
    },
    "rootDir": "./src",
    "outDir": "./dist",
    "typeRoots": [
      "./node_modules/@types"
    ],
    "types": [
      "google-apps-script"
    ],
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.ts",
    "types/**/*.d.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
